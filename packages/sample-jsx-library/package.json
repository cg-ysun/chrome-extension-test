{
    "name": "@cargurus/sample-jsx-library",
    "version": "0.0.0",
    "description": "Example of an npm library that contains jsx",
    "author": "CarGurus",
    "repository": {
        "url": "https://code.cargurus.com/cargurus-eng/cargurus-npm-library-template",
        "type": "git"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/types/index.d.ts",
    "files": [
        "*.d.ts",
        "dist"
    ],
    "scripts": {
        "all": "rm -rf .eslintcache && npm-run-all --parallel lint test",
        "build": "vite build --config \"./vite.config.mts\"",
        "build:watch": "yarn run build --watch",
        "dev": "npm-run-all --parallel build:watch typeless:watch",
        "coverage": "yarn test --coverage",
        "eslint:fix": "eslint . --fix",
        "eslint": "eslint .",
        "lint:fix": "npm-run-all --parallel eslint:fix test:tsc typeless:fix",
        "lint": "npm-run-all --parallel eslint prettier test:tsc typeless",
        "prettier:fix": "prettier --ignore-unknown --write .",
        "prettier": "prettier --list-different --ignore-unknown .",
        "test:watch": "yarn test --watch",
        "test:tsc": "tsc",
        "typeless:fix": "typeless .",
        "typeless": "typeless . --dry-run",
        "typeless:watch": "typeless . --watch",
        "test": "NODE_ENV=test vitest run --config=\"./vitest.config.mts\"",
        "storybook": "storybook dev -p 6006",
        "build:storybook": "storybook build -o storybook-static",
        "prepublishOnly": "yarn run build"
    },
    "prettier": "@cargurus/prettier-config",
    "dependencies": {
        "react": "^18.2.0"
    },
    "devDependencies": {
        "@cargurus/eslint-config": "0.0.5",
        "@cargurus/prettier-config": "0.0.4",
        "@cargurus/typeless": "^1.1.1",
        "@cargurus/vite-plugin-yalc": "^0.4.0",
        "@rollup/plugin-typescript": "^11.1.1",
        "@storybook/addon-essentials": "^7.0.18",
        "@storybook/addon-interactions": "^7.0.18",
        "@storybook/addon-links": "^7.0.18",
        "@storybook/blocks": "^7.0.18",
        "@storybook/react": "^7.0.18",
        "@storybook/react-vite": "^7.0.18",
        "@storybook/testing-library": "^0.0.14-next.2",
        "@testing-library/jest-dom": "^5.17.0",
        "@testing-library/react": "^14.0.0",
        "@types/node": "^20.2.5",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/coverage-v8": "^3.0.8",
        "enzyme": "3.10.0",
        "eslint": "^8.51.0",
        "happy-dom": "^20.0.2",
        "less": "^4.2.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.0.3",
        "prop-types": "^15.8.1",
        "react-dom": "^18.2.0",
        "rollup-plugin-visualizer": "^5.14.0",
        "storybook": "^7.0.18",
        "stylelint": "7.13.0",
        "tslib": "^2.5.3",
        "typescript": "^5.1.3",
        "vite": "^6.4.1",
        "vite-plugin-dts": "^4.5.3",
        "vite-plugin-libcss": "^1.1.1",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.0.8"
    },
    "cg_meta": {
        "packageTemplate": "@js-renaissance-tooling/cpt-react@1.0.5"
    }
}
