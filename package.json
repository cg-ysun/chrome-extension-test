{
  "name": "chrome-extension-test-root",
  "version": "1.0.0",
  "packageManager": "yarn@3.6.4",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach --topological-dev --parallel -v run build",
    "build:storybook": "yarn workspaces foreach --topological-dev --parallel -v run build:storybook",
    "ci:prePublish": "yarn build",
    "ci:build": "yarn build",
    "ci:buildStorybook": "yarn build:storybook",
    "clean:all": "npm-run-all clean:build clean:install",
    "clean:build": "find . \\( -path \"*/dist/*\" -o -path \"*/storybook-static/*\" \\) -not -path \"*/node_modules/*\" -prune -exec rm -rf \\{\\} \\;",
    "clean:install": "find . -path \"*node_modules*\" -prune -exec rm -rf \\{\\} \\;",
    "eslint": "yarn workspaces foreach --topological-dev --parallel -v run eslint",
    "eslint:fix": "yarn workspaces foreach --topological-dev --parallel -v run eslint:fix",
    "lint": "yarn workspaces foreach --topological-dev --parallel -v run lint",
    "prettier": "yarn workspaces foreach --topological-dev --parallel -v run prettier",
    "prettier:fix": "yarn workspaces foreach --topological-dev --parallel -v run prettier:fix",
    "test": "yarn workspaces foreach --topological-dev --parallel -v run test",
    "test:tsc": "yarn workspaces foreach --topological-dev --parallel -v run test:tsc",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "npm-run-all": "^4.1.5",
    "snyk": "^1.1303.1"
  }
}
